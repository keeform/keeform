{
  "name":           "KeeForm",
  "description":    "KeeForm - A simple KeePass form filler",
  "version":        "5.0.0",
  "manifest_version": 3,
  "background": {
    "service_worker": "keeformext.js"
  },
  "web_accessible_resources": [{
    "resources": ["icons/icon19o.png", "icons/icon19o.png", "icons/tile96.png"],
    "matches": ["<all_urls>"],
    "extension_ids": []
  }],
  "action": {
    "default_icon": {
      "19": "icons/icon19.png",
      "38": "icons/icon38.png"
    },
    "default_title": "KeeForm"
  },
"icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
},

  "host_permissions":  [
    "<all_urls>"
  ],
  "permissions":  [
    "webRequest", "webRequestAuthProvider", "storage", "scripting"
  , "tabs", "notifications","nativeMessaging", "webNavigation"
  ],
"options_ui":{
    "open_in_tab": true,
    "page": "options/options.html"
  }
}
